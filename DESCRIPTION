Package: qardlr
Type: Package
Title: Quantile Autoregressive Distributed Lag Model
Version: 1.0.1
Date: 2026-03-07
Authors@R: c(
    person("Muhammad", "Alkhalaf", 
           email = "muhammedalkhalaf@gmail.com",
           role = c("aut", "cre", "cph"),
           comment = c(ORCID = "0009-0002-2677-9246")),
    person("Jin Seo", "Cho", role = "ctb", comment = "Original methodology"),
